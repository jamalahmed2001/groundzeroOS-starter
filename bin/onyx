#!/usr/bin/env bash
# onyx — v2 dispatcher.
#
# Builds a prompt for one of the six v2 verbs and spawns the configured
# coding agent (Claude Code by default). The verb semantics live in
# `08 - System/ONYX v2 Runtime.md` inside the vault — this script does not
# embed them.
#
# Usage:
#   onyx <verb> [args...]
#
# Verbs:
#   new <project> [--kind X] [--repo path]      Scaffold a project bundle
#   execute <project> [phase]                    Run the phase hot loop (system-changing)
#   run <project> <pipeline> [--input X]         Run a pipeline (repeatable)
#   heal                                          Rebuild Status + Dashboard, free stale locks
#   compact <project>[/<file>]                   Archive + rewrite an append-only file
#   consolidate                                   Emit cross-project wisdom diff for review
#
# Convenience aliases (mapped to verbs above):
#   status [project]                              -> "read Status.md and report"
#   resume [project]                              -> "cold-start, then execute the active phase"

set -eo pipefail

ONYX_HOME="$(cd "$(dirname "$0")/.." && pwd)"

# Source config — exports ONYX_VAULT_ROOT etc. into our env
if [[ -x "$ONYX_HOME/clawd-skills/config-load/bin/config-load" ]]; then
  eval "$("$ONYX_HOME/clawd-skills/config-load/bin/config-load" --cwd "$ONYX_HOME" 2>/dev/null || true)"
fi

VAULT_ROOT="${ONYX_VAULT_ROOT:-$ONYX_HOME/vault}"

if [[ $# -eq 0 ]]; then
  cat <<USAGE
onyx — vault-native agent orchestration (v2)

usage: onyx <verb> [args...]

verbs (full spec in $VAULT_ROOT/08 - System/ONYX v2 Runtime.md):
  new <project> [--kind X] [--repo path]   scaffold a project bundle
  execute <project> [phase]                run the phase hot loop
  run <project> <pipeline> [--input X]     run a pipeline
  heal                                      rebuild Status + Dashboard, free stale locks
  compact <project>[/<file>]               archive + rewrite an append-only file
  consolidate                               emit cross-project wisdom diff

convenience aliases:
  status [project]                          show what's active / blocked
  resume [project]                          cold-start + execute the active phase

env:
  ONYX_VAULT_ROOT     path to your vault (overrides config)
  ONYX_AGENT_DRIVER   claude-code (default) or cursor

config: $ONYX_HOME/onyx.config.json
vault:  $VAULT_ROOT
home:   $ONYX_HOME
USAGE
  exit 0
fi

VERB="$1"
shift
ARGS=("$@")

case "$VERB" in
  new|execute|run|heal|compact|consolidate|status|resume) ;;
  *)
    echo "[onyx] unknown verb: $VERB" >&2
    echo "       Run 'onyx' with no args for the verb list." >&2
    exit 1
    ;;
esac

PROMPT="$(cat <<EOF
You are operating under ONYX v2. Read \`08 - System/ONYX v2 Runtime.md\` end-to-end if you have not already this session, then follow its procedures exactly.

Verb: \`$VERB\`
Operator arguments: ${ARGS[*]:-(none)}

Vault root: $VAULT_ROOT
Onyx home:  $ONYX_HOME

If the verb is \`status\` or \`resume\`, run cold-start (§A) and report. For \`status\`, stop after the report. For \`resume\`, proceed into the phase hot loop (§B) on the active phase.

Use only agent-native primitives (Read, Write, Edit, Bash, Glob) and the skills in \`08 - System/Agent Skills/\`. Never assume a v1 directive folder exists.
EOF
)"

DRIVER="${ONYX_AGENT_DRIVER:-claude-code}"
AGENT_SPAWN="$ONYX_HOME/clawd-skills/agent-spawn/bin/agent-spawn"

if [[ -x "$AGENT_SPAWN" ]]; then
  echo "$PROMPT" | "$AGENT_SPAWN" --driver "$DRIVER" --repo "$ONYX_HOME"
else
  case "$DRIVER" in
    claude-code)
      exec claude --dangerously-skip-permissions --output-format text --print "$PROMPT" --add-dir "$ONYX_HOME"
      ;;
    cursor)
      exec cursor agent --print --yolo --output-format text --workspace "$ONYX_HOME" "$PROMPT"
      ;;
    *)
      echo "[onyx] unknown agent driver: $DRIVER" >&2
      exit 2
      ;;
  esac
fi
